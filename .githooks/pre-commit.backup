
#!/usr/bin/env bash
# File: .githooks/pre-commit
# Purpose: Fast local checks before creating a commit

set -e

echo "[pre-commit] Running fast unit tests via uv..."

# Optional: add fast lint / format here (must stay very quick)
# uv run ruff check .
# uv run ruff format --check .

# Fast unit tests only (using a pytest marker 'unit')
uv run pytest
RESULT=$?

if [ $RESULT -ne 0 ]; then
  echo "[pre-commit] Unit tests failed. Commit aborted."
  exit $RESULT
fi

echo "[pre-commit] OK"
exit 0
